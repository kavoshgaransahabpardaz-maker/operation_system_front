# ── Frontend ──────────────────────────────────────────────────────────────────
# Port the frontend Nginx container binds on the host
FRONTEND_PORT=80

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_64_HEX_CHARS

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=broker
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=brokerai

DATABASE_URL=postgresql+asyncpg://broker:CHANGE_ME_STRONG_PASSWORD@postgres:5432/brokerai
DATABASE_URL_SYNC=postgresql+psycopg2://broker:CHANGE_ME_STRONG_PASSWORD@postgres:5432/brokerai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=CHANGE_ME_MINIO_USER
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET_NAME=brokerai-documents
S3_REGION=us-east-1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Email OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://YOUR_DOMAIN/api/v1/email/oauth/gmail/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://YOUR_DOMAIN/api/v1/email/oauth/microsoft/callback

# ── Token encryption key ──────────────────────────────────────────────────────
# Generate: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_KEY
