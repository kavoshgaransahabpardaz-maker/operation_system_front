# Port the frontend Nginx container exposes on the host
FRONTEND_PORT=80

# Backend API base URL — Nginx proxies /api/* to this address
BACKEND_URL=https://api.veritariffai.co

# Google OAuth 2.0 Client ID (required for sign-in)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
